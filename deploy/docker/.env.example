# Llamenos Self-Hosted Configuration
#
# Quick start: run ../../scripts/docker-setup.sh to auto-generate this file.
# Or copy this to .env and fill in values manually.

# ─── Required Secrets ──────────────────────────────────────────
# All of these are auto-generated by scripts/docker-setup.sh.
# To generate manually: openssl rand -hex 32 (for hex) or openssl rand -base64 24 (for passwords)

PG_PASSWORD=
HMAC_SECRET=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
SERVER_NOSTR_SECRET=

# ─── Domain & TLS ──────────────────────────────────────────────
# For local development: leave defaults (HTTP on port 8000)
# For production: set DOMAIN to your real domain (Caddy auto-provisions TLS via Let's Encrypt)
DOMAIN=localhost
CADDY_SITE_ADDRESS=http://localhost
ACME_EMAIL=

# ─── Application ───────────────────────────────────────────────
HOTLINE_NAME=Hotline
ENVIRONMENT=production

# ─── Admin (optional) ─────────────────────────────────────────
# Leave empty to create the admin account via the setup wizard (recommended).
# Set these only if pre-provisioning the admin via CLI (bun run bootstrap-admin).
# ADMIN_PUBKEY=
# ADMIN_DECRYPTION_PUBKEY=

# ─── Demo Mode ─────────────────────────────────────────────────
# Set to "true" to enable demo mode (pre-seeded data, one-click login).
# DEMO_MODE=true

# ─── Telephony ─────────────────────────────────────────────────
# Configure via the admin UI after first login, or set env vars here.
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=

# ─── MinIO (Blob Storage) ─────────────────────────────────────
MINIO_BUCKET=llamenos-files

# ─── Optional Profiles ────────────────────────────────────────
# Enable with: docker compose --profile <name> up -d
# Options: transcription, asterisk, signal
# COMPOSE_PROFILES=transcription

# ─── Transcription ────────────────────────────────────────────
# WHISPER_MODEL=Systran/faster-whisper-base
# WHISPER_DEVICE=cpu

# ─── Asterisk (Self-Hosted PBX) ───────────────────────────────
# Required if using --profile asterisk:
# ARI_PASSWORD=
# BRIDGE_SECRET=

# ─── Push Notifications (Web Push / VAPID) ────────────────────
# Generate with: bun -e "const wp = require('web-push'); const k = wp.generateVAPIDKeys(); console.log('VAPID_PUBLIC_KEY=' + k.publicKey); console.log('VAPID_PRIVATE_KEY=' + k.privateKey)"
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=

# ─── Watchtower (Auto-Updates) ────────────────────────────────
# Only active when using docker-compose.production.yml.
# Watchtower watches only the app container (label-enabled filtering).
#
# GHCR credentials — required only if the app image is in a private registry.
# Create a GitHub PAT with read:packages scope:
#   https://github.com/settings/tokens/new?scopes=read:packages
# GHCR_USERNAME=your-github-username
# GHCR_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
#
# How often to check for updates (seconds). Default: 86400 (24h).
# WATCHTOWER_POLL_INTERVAL=86400
#
# Log verbosity: info | debug | warn | error
# WATCHTOWER_LOG_LEVEL=info

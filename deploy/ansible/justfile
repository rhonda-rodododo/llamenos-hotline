# Llamenos Ansible Deployment Commands
#
# Prerequisites:
#   - Ansible installed (pip install ansible)
#   - just installed (https://github.com/casey/just)
#   - inventory.yml and vars.yml configured
#
# Quick start:
#   cp inventory.example.yml inventory.yml
#   cp vars.example.yml vars.yml
#   # Edit both files with your values
#   ansible-vault encrypt vars.yml
#   just setup-all

# Default recipe: show available commands
default:
    @just --list

# Full server setup: harden + deploy
setup-all *ARGS:
    ansible-playbook setup.yml --ask-vault-pass {{ARGS}}

# Harden the server (SSH, firewall, kernel, fail2ban, Docker)
harden *ARGS:
    ansible-playbook playbooks/harden.yml --ask-vault-pass {{ARGS}}

# Deploy or update the application
deploy *ARGS:
    ansible-playbook playbooks/deploy.yml --ask-vault-pass {{ARGS}}

# Pull latest images and restart with health check and rollback
update *ARGS:
    ansible-playbook playbooks/update.yml --ask-vault-pass {{ARGS}}

# Run encrypted backup
backup *ARGS:
    ansible-playbook playbooks/backup.yml --ask-vault-pass {{ARGS}}

# Check configuration without making changes
check *ARGS:
    ansible-playbook setup.yml --check --diff --ask-vault-pass {{ARGS}}

# Validate playbooks without making changes (CI-safe, uses example inventory and vars)
validate *ARGS:
    ansible-lint .
    ansible-playbook setup.yml --check --diff \
        -i inventory.example.yml \
        --extra-vars "@vars.example.yml" \
        {{ARGS}}

# Show what would change on the server (requires vault password)
dry-run *ARGS:
    ansible-playbook setup.yml --check --diff --ask-vault-pass {{ARGS}}

# Encrypt the vars file with Ansible Vault
encrypt-vars:
    ansible-vault encrypt vars.yml

# Edit encrypted vars file
edit-vars:
    ansible-vault edit vars.yml

# View encrypted vars file
view-vars:
    ansible-vault view vars.yml

# Test SSH connectivity to all hosts
ping:
    ansible all -m ping

# Show gathered facts for debugging
facts:
    ansible all -m setup --ask-vault-pass

# Deploy or update the demo instance
deploy-demo *ARGS:
    ansible-playbook playbooks/deploy-demo.yml --ask-vault-pass {{ARGS}}

# Reset demo data on demand
reset-demo *ARGS:
    ansible-playbook playbooks/reset-demo.yml --ask-vault-pass {{ARGS}}

# Roll back demo to a specific image tag (e.g.: just rollback-demo v1.2.3)
rollback-demo version *ARGS:
    ansible-playbook playbooks/deploy-demo.yml --ask-vault-pass \
        --extra-vars "llamenos_image=ghcr.io/llamenos/llamenos:{{version}}" \
        {{ARGS}}

# Run an encrypted backup of the demo instance
backup-demo *ARGS:
    ansible-playbook playbooks/backup.yml --ask-vault-pass -l demo {{ARGS}}

# Test that the latest demo backup can be restored
test-restore-demo *ARGS:
    ansible-playbook playbooks/test-restore.yml --ask-vault-pass -l demo {{ARGS}}

# Restore a specific backup to the demo database (e.g.: just restore-demo s3:bucket/llamenos-20260101-030000.sql.gz.age)
restore-demo backup_file *ARGS:
    ansible-playbook playbooks/restore.yml --ask-vault-pass -l demo \
        --extra-vars "restore_backup_file={{backup_file}}" \
        {{ARGS}}

# Encrypt the demo vars file
encrypt-demo-vars:
    ansible-vault encrypt demo_vars.yml

# Edit encrypted demo vars file
edit-demo-vars:
    ansible-vault edit demo_vars.yml

# ─── Local VM Testing (Tart on Mac) ──────────────────────────────
# Requires: Tart + Docker on Mac, SSH access as 'mac'
# See: docs/plans/2026-03-25-local-vm-ansible-testing.md

# Create and configure a fresh Tart VM for testing
vm-create:
    ssh mac 'source ~/.zprofile && tart clone ghcr.io/cirruslabs/ubuntu:24.04 llamenos-test && tart set llamenos-test --cpu 2 --memory 4096 --disk-size 20'

# Start the VM headless
vm-start:
    ssh mac 'source ~/.zprofile && tart run llamenos-test --no-graphics &'
    @echo "Waiting for VM to boot..."
    @sleep 10
    @ssh mac 'source ~/.zprofile && tart ip llamenos-test'

# Stop the VM
vm-stop:
    ssh mac 'source ~/.zprofile && tart stop llamenos-test'

# Destroy the VM
vm-destroy:
    ssh mac 'source ~/.zprofile && tart delete llamenos-test'

# Show VM IP
vm-ip:
    @ssh mac 'source ~/.zprofile && tart ip llamenos-test'

# SSH into the VM through the Mac (port 2222 after hardening)
vm-ssh:
    ssh -J mac -p 2222 deploy@$(ssh mac 'source ~/.zprofile && tart ip llamenos-test')

# Build the Docker image on the Mac (ARM64 native)
vm-build-image:
    ssh mac 'export PATH="/usr/local/bin:/opt/homebrew/bin:$$PATH" && cd ~/projects/llamenos-hotline && docker build -f deploy/docker/Dockerfile -t llamenos:local .'

# Load the built image into the VM (port 2222 after hardening)
vm-load-image:
    ssh mac 'source ~/.zprofile && export PATH="/usr/local/bin:$$PATH" && docker save llamenos:local | gzip | ssh -p 2222 deploy@$$(tart ip llamenos-test) "gunzip | sudo docker load"'

# Deploy to the VM using Ansible (run from Mac)
vm-deploy *ARGS:
    ssh mac 'cd ~/projects/llamenos-hotline/deploy/ansible && source ~/.zprofile && ansible-playbook setup.yml -i inventory-local-vm.yml --extra-vars "@vars-local-vm.yml" {{ARGS}}'

# Deploy only app changes (skip hardening)
vm-deploy-app *ARGS:
    ssh mac 'cd ~/projects/llamenos-hotline/deploy/ansible && source ~/.zprofile && ansible-playbook playbooks/deploy.yml -i inventory-local-vm.yml --extra-vars "@vars-local-vm.yml" {{ARGS}}'

# Update app (pull new image + restart with health check)
vm-update *ARGS:
    ssh mac 'cd ~/projects/llamenos-hotline/deploy/ansible && source ~/.zprofile && ansible-playbook playbooks/update.yml -i inventory-local-vm.yml --extra-vars "@vars-local-vm.yml" {{ARGS}}'

# Run E2E tests against the VM from the Mac
vm-test *ARGS:
    ssh mac 'export PATH="/usr/local/bin:/opt/homebrew/bin:$$PATH" && cd ~/projects/llamenos-hotline && npx playwright test --config playwright.vm.config.ts {{ARGS}}'

# Full cycle: build image, load into VM, deploy, run tests
vm-cycle:
    just vm-build-image
    just vm-load-image
    just vm-deploy-app
    just vm-test

# Snapshot the VM for fast iteration resets
vm-snapshot:
    ssh mac 'source ~/.zprofile && tart stop llamenos-test && tart clone llamenos-test llamenos-test-snapshot'
    @echo "Snapshot created. Restore with: just vm-restore"

# Restore VM from snapshot
vm-restore:
    ssh mac 'source ~/.zprofile && tart stop llamenos-test 2>/dev/null; tart delete llamenos-test 2>/dev/null; tart clone llamenos-test-snapshot llamenos-test'
    just vm-start

# Generate secrets for a new deployment
generate-secrets:
    #!/usr/bin/env bash
    set -euo pipefail
    echo "=== Generated Secrets ==="
    echo ""
    echo "pg_password: $(openssl rand -base64 24)"
    echo "hmac_secret: $(openssl rand -hex 32)"
    echo "minio_access_key: $(openssl rand -base64 24)"
    echo "minio_secret_key: $(openssl rand -base64 24)"
    echo "minio_app_user: llamenos-app"
    echo "minio_app_password: $(openssl rand -base64 24)"
    echo "ari_password: $(openssl rand -base64 24)"
    echo "bridge_secret: $(openssl rand -base64 24)"
    echo ""
    echo "Copy these into your vars.yml before encrypting."
    echo "Run: just encrypt-vars"

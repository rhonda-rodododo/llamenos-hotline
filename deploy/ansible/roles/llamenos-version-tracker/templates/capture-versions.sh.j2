#!/usr/bin/env bash
# Capture current Docker image digests and tags for all running services.
# Output: JSON object mapping service name to { image, digest }.
set -euo pipefail

cd "{{ app_dir }}"

# Get image info for each service defined in docker-compose.yml
services=$(docker compose config --services 2>/dev/null || true)
if [ -z "$services" ]; then
  echo '{}'
  exit 0
fi

echo '{'
first=true
for svc in $services; do
  # Get the image reference for this service
  image=$(docker compose images "$svc" --format json 2>/dev/null | \
    python3 -c "import sys,json; data=json.load(sys.stdin); print(data[0].get('Repository','') + ':' + data[0].get('Tag','') if data else '')" 2>/dev/null || true)

  # Get the digest
  digest=$(docker compose images "$svc" --format json 2>/dev/null | \
    python3 -c "import sys,json; data=json.load(sys.stdin); print(data[0].get('ID','') if data else '')" 2>/dev/null || true)

  if [ -n "$image" ] && [ "$image" != ":" ]; then
    if [ "$first" = true ]; then
      first=false
    else
      echo ','
    fi
    printf '  "%s": {"image": "%s", "digest": "%s"}' "$svc" "$image" "$digest"
  fi
done
echo ''
echo '}'

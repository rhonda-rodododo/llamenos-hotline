# Llamenos application environment — managed by Ansible
# Do not edit directly; changes will be overwritten on next deploy.

# ─── Platform & Runtime ─────────────────────────────────────────
PLATFORM=node
PORT=3000
ENVIRONMENT={{ app_environment | default('production') }}
DEMO_MODE={{ demo_mode | default('') }}
DEV_RESET_SECRET={{ dev_reset_secret | default('') }}
HOTLINE_NAME={{ hotline_name | default('Hotline') }}

# ─── Database ───────────────────────────────────────────────────
DATABASE_URL=postgresql://llamenos:{{ pg_password | urlencode | replace('/', '%2F') }}@postgres:5432/llamenos
PG_POOL_SIZE={{ pg_pool_size | default(20) }}

# ─── Identity & Auth ───────────────────────────────────────────
ADMIN_PUBKEY={{ admin_pubkey | default('') }}
ADMIN_DECRYPTION_PUBKEY={{ admin_decryption_pubkey | default('') }}
HMAC_SECRET={{ hmac_secret }}

# ─── IdP Auth (Authentik) ──────────────────────────────────────
JWT_SECRET={{ jwt_secret }}
IDP_ADAPTER={{ idp_adapter | default('authentik') }}
IDP_VALUE_ENCRYPTION_KEY={{ idp_value_encryption_key }}
IDP_VALUE_KEY_VERSION={{ idp_value_key_version | default(1) }}
AUTHENTIK_URL={{ authentik_url | default('http://authentik-server:9000') }}
AUTHENTIK_API_TOKEN={{ authentik_api_token | default(authentik_bootstrap_token) }}
AUTHENTIK_SECRET_KEY={{ authentik_secret_key }}
AUTHENTIK_BOOTSTRAP_TOKEN={{ authentik_bootstrap_token }}

# ─── WebAuthn ──────────────────────────────────────────────────
AUTH_WEBAUTHN_RP_ID={{ auth_webauthn_rp_id | default(domain | default('localhost')) }}
AUTH_WEBAUTHN_RP_NAME={{ auth_webauthn_rp_name | default('Llamenos') }}
AUTH_WEBAUTHN_ORIGIN={{ auth_webauthn_origin | default('https://' + (domain | default('localhost'))) }}

# ─── Storage (RustFS — S3-compatible, bucket management handled by app) ──
STORAGE_ENDPOINT=http://rustfs:9000
STORAGE_ACCESS_KEY={{ storage_access_key }}
STORAGE_SECRET_KEY={{ storage_secret_key }}
STORAGE_SSE_ENABLED={{ storage_sse_enabled | default('true') }}

# ─── Nostr Relay ────────────────────────────────────────────────
SERVER_NOSTR_SECRET={{ server_nostr_secret }}
NOSTR_RELAY_URL={{ nostr_relay_url | default('ws://strfry:7777') }}

# ─── Telephony (Twilio) ────────────────────────────────────────
TWILIO_ACCOUNT_SID={{ twilio_account_sid | default('') }}
TWILIO_AUTH_TOKEN={{ twilio_auth_token | default('') }}
TWILIO_PHONE_NUMBER={{ twilio_phone_number | default('') }}

# ─── Transcription ──────────────────────────────────────────────
WHISPER_URL={{ whisper_url | default('http://whisper:8080/v1/audio/transcriptions') }}
{% if extra_env is defined %}

# ─── Extra environment (local overrides) ──────────────────────────
{% for key, value in extra_env.items() %}
{{ key }}={{ value }}
{% endfor %}
{% endif %}

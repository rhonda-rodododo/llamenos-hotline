# Llamenos application environment — managed by Ansible
# Do not edit directly; changes will be overwritten on next deploy.

# ─── Platform & Runtime ─────────────────────────────────────────
PLATFORM=node
PORT=3000
ENVIRONMENT={{ environment | default('production') }}
DEMO_MODE={{ demo_mode | default('') }}
DEV_RESET_SECRET={{ dev_reset_secret | default('') }}
HOTLINE_NAME={{ hotline_name | default('Hotline') }}

# ─── Database ───────────────────────────────────────────────────
DATABASE_URL=postgresql://llamenos:{{ pg_password | urlencode | replace('/', '%2F') }}@postgres:5432/llamenos
PG_POOL_SIZE={{ pg_pool_size | default(10) }}

# ─── Identity & Auth ───────────────────────────────────────────
ADMIN_PUBKEY={{ admin_pubkey | default('') }}
ADMIN_DECRYPTION_PUBKEY={{ admin_decryption_pubkey | default('') }}
HMAC_SECRET={{ hmac_secret }}

# ─── Blob Storage (MinIO) ──────────────────────────────────────
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY={{ minio_access_key }}
MINIO_SECRET_KEY={{ minio_secret_key }}
MINIO_BUCKET={{ minio_bucket | default('llamenos-files') }}

# ─── Nostr Relay ────────────────────────────────────────────────
SERVER_NOSTR_SECRET={{ server_nostr_secret }}
NOSTR_RELAY_URL={{ nostr_relay_url | default('ws://strfry:7777') }}

# ─── Telephony (Twilio) ────────────────────────────────────────
TWILIO_ACCOUNT_SID={{ twilio_account_sid | default('') }}
TWILIO_AUTH_TOKEN={{ twilio_auth_token | default('') }}
TWILIO_PHONE_NUMBER={{ twilio_phone_number | default('') }}

# ─── Transcription ──────────────────────────────────────────────
WHISPER_URL={{ whisper_url | default('http://whisper:8080/v1/audio/transcriptions') }}

# Caddyfile for Llamenos — managed by Ansible
# Do not edit directly; changes will be overwritten on next deploy.
{% if tls_mode | default('acme') == 'off' %}
:80 {
{% elif tls_mode | default('acme') == 'internal' %}
{{ domain }} {
	# TLS via Caddy's internal CA (local/dev use)
	tls internal
{% else %}
{{ domain }} {
	# TLS via Let's Encrypt
	tls {{ acme_email }}
{% endif %}

	# API, telephony, and messaging routes -> app
	handle /api/* {
		reverse_proxy app:3000
	}

	handle /telephony/* {
		reverse_proxy app:3000
	}

	handle /messaging/* {
		reverse_proxy app:3000
	}

	# Nostr relay WebSocket proxy -> strfry
	handle /nostr {
		reverse_proxy strfry:7777
	}

	# Everything else -> app (serves SPA static files)
	handle {
		reverse_proxy app:3000
	}

	# Security headers
	header {
{% if tls_mode | default('acme') != 'off' %}
		Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
{% endif %}
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		X-Permitted-Cross-Domain-Policies "none"
{% if tls_mode | default('acme') == 'off' %}
		Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self'; connect-src 'self' ws://{{ domain }}/nostr wss://{{ domain }}/nostr; media-src 'self' blob:; object-src 'none'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'"
{% else %}
		Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self'; connect-src 'self' wss://{{ domain }}/nostr; media-src 'self' blob:; object-src 'none'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'"
{% endif %}
		Permissions-Policy "camera=(), microphone=(self), geolocation=(), payment=(), usb=(), magnetometer=(), gyroscope=(), accelerometer=()"
		-Server
	}

	encode gzip zstd
}

# Llamenos Docker Compose — managed by Ansible
# Do not edit manually; changes will be overwritten on next deploy.
#
# Generated: {{ ansible_date_time.iso8601 | default('unknown') }}
# Domain: {{ domain }}

name: llamenos

services:
  # ── Core Services ──────────────────────────────────────────

  app:
    image: {{ llamenos_image }}
    restart: unless-stopped
    read_only: true
    tmpfs:
      - /tmp:size=64M
    volumes:
      - {{ app_dir }}/backups/.status.json:/var/data/backup-status.json:ro
    environment:
      - PLATFORM=node
      - PORT=3000
      - DATABASE_URL=postgresql://llamenos:${PG_PASSWORD}@postgres:5432/llamenos
      - PG_POOL_SIZE=${PG_POOL_SIZE}
      - ADMIN_PUBKEY=${ADMIN_PUBKEY}
      - HOTLINE_NAME=${HOTLINE_NAME}
      - ENVIRONMENT=${ENVIRONMENT}
      - HMAC_SECRET=${HMAC_SECRET}
      - MINIO_ENDPOINT=http://minio:9000
      - MINIO_ACCESS_KEY=${MINIO_APP_USER}
      - MINIO_SECRET_KEY=${MINIO_APP_PASSWORD}
      - MINIO_BUCKET=${MINIO_BUCKET}
      - WHISPER_URL=${WHISPER_URL}
      - TWILIO_ACCOUNT_SID=${TWILIO_ACCOUNT_SID}
      - TWILIO_AUTH_TOKEN=${TWILIO_AUTH_TOKEN}
      - TWILIO_PHONE_NUMBER=${TWILIO_PHONE_NUMBER}
      - SERVER_NOSTR_SECRET=${SERVER_NOSTR_SECRET}
      - NOSTR_RELAY_URL=${NOSTR_RELAY_URL}
      # IdP Auth (Authentik)
      - IDP_ADAPTER=${IDP_ADAPTER}
      - AUTHENTIK_URL=${AUTHENTIK_URL}
      - AUTHENTIK_API_TOKEN=${AUTHENTIK_BOOTSTRAP_TOKEN}
      - IDP_VALUE_ENCRYPTION_KEY=${IDP_VALUE_ENCRYPTION_KEY}
      - IDP_VALUE_KEY_VERSION=${IDP_VALUE_KEY_VERSION}
      - JWT_SECRET=${JWT_SECRET}
      - AUTH_WEBAUTHN_RP_ID=${AUTH_WEBAUTHN_RP_ID}
      - AUTH_WEBAUTHN_RP_NAME=${AUTH_WEBAUTHN_RP_NAME}
      - AUTH_WEBAUTHN_ORIGIN=${AUTH_WEBAUTHN_ORIGIN}
    networks:
      - web
      - internal
    depends_on:
      postgres:
        condition: service_healthy
      minio:
        condition: service_healthy
      strfry:
        condition: service_healthy
      authentik-server:
        condition: service_healthy
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:3000/api/health"]
      interval: 15s
      timeout: 5s
      retries: 5
      start_period: 20s
    security_opt:
      - no-new-privileges:true
    deploy:
      resources:
        limits:
          memory: 512M
    labels:
      com.centurylinklabs.watchtower.enable: "true"

  postgres:
    image: {{ postgres_image }}
    restart: unless-stopped
    volumes:
      - postgres-data:/var/lib/postgresql/data
      - {{ app_dir }}/postgres-init:/docker-entrypoint-initdb.d:ro
    environment:
      - POSTGRES_DB=llamenos
      - POSTGRES_USER=llamenos
      - POSTGRES_PASSWORD=${PG_PASSWORD}
    networks:
      - internal
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U llamenos -d llamenos"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 10s
    security_opt:
      - no-new-privileges:true
    deploy:
      resources:
        limits:
          memory: 512M

  caddy:
    image: {{ caddy_image }}
    restart: unless-stopped
    ports:
      - "80:80"
      - "443:443"
      - "443:443/udp"
    volumes:
      - ./Caddyfile:/etc/caddy/Caddyfile:ro
      - caddy-data:/data
      - caddy-config:/config
    networks:
      - web
    depends_on:
      app:
        condition: service_healthy
    security_opt:
      - no-new-privileges:true
    deploy:
      resources:
        limits:
          memory: 128M

  minio:
    image: {{ minio_image }}
    command: server /data --console-address ":9001"
    restart: unless-stopped
    volumes:
      - minio-data:/data
    environment:
      - MINIO_ROOT_USER=${MINIO_ACCESS_KEY}
      - MINIO_ROOT_PASSWORD=${MINIO_SECRET_KEY}
    networks:
      - internal
    healthcheck:
      test: ["CMD", "mc", "ready", "local"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 10s
    security_opt:
      - no-new-privileges:true
    deploy:
      resources:
        limits:
          memory: 256M

{% if 'transcription' in compose_profiles %}
  # ── Optional: Whisper Transcription ──────────────────────────

  whisper:
    image: {{ whisper_image }}
    restart: unless-stopped
    environment:
      - WHISPER__MODEL=${WHISPER_MODEL}
      - WHISPER__DEVICE=${WHISPER_DEVICE}
    networks:
      - internal
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:8080/health"]
      interval: 30s
      timeout: 5s
      retries: 3
      start_period: 30s
    security_opt:
      - no-new-privileges:true
{% endif %}

{% if 'asterisk' in compose_profiles %}
  # ── Optional: Asterisk PBX ──────────────────────────────────

  asterisk:
    image: {{ asterisk_image }}
    restart: unless-stopped
    volumes:
      - asterisk-config:/etc/asterisk
    networks:
      - internal
      - web
    healthcheck:
      test: ["CMD", "asterisk", "-rx", "core show version"]
      interval: 30s
      timeout: 5s
      retries: 3
      start_period: 15s
    security_opt:
      - no-new-privileges:true

  asterisk-bridge:
    image: {{ llamenos_image }}-asterisk-bridge
    restart: unless-stopped
    environment:
      - ARI_URL=ws://asterisk:8088/ari/events
      - ARI_USERNAME=${ARI_USERNAME}
      - ARI_PASSWORD=${ARI_PASSWORD}
      - WORKER_WEBHOOK_URL=http://app:3000
      - BRIDGE_SECRET=${BRIDGE_SECRET}
    networks:
      - internal
    depends_on:
      asterisk:
        condition: service_healthy
      app:
        condition: service_healthy
    security_opt:
      - no-new-privileges:true

  # ── coturn TURN/STUN server ──────────────────────────────────
  # Required for WebRTC NAT traversal. Volunteers behind NAT use
  # TURN relay for media when direct peer-to-peer fails.
  coturn:
    image: {{ coturn_image | default('coturn/coturn:4.6') }}
    restart: unless-stopped
    ports:
      - "3478:3478"       # STUN/TURN UDP
      - "3478:3478/tcp"   # STUN/TURN TCP
      - "5349:5349"       # STUN/TURN TLS
      - "5349:5349/tcp"   # STUN/TURN TLS TCP
      - "49152-49252:49152-49252/udp"  # TURN relay ports
    volumes:
      - ./turnserver.conf:/etc/turnserver.conf:ro
{% if coturn_cert_path is defined %}
      - {{ coturn_cert_path }}:/etc/ssl/turn/cert.pem:ro
      - {{ coturn_key_path }}:/etc/ssl/turn/key.pem:ro
{% endif %}
    networks:
      - web
      - internal
    security_opt:
      - no-new-privileges:true
{% endif %}

  # ── Core: Nostr Relay (strfry) ──────────────────────────────

  strfry:
    image: {{ strfry_image | default('dockurr/strfry:latest') }}
    restart: unless-stopped
    volumes:
      - nostr-data:/app/strfry-db
    networks:
      - internal
    healthcheck:
      test: ["CMD", "curl", "-sf", "http://localhost:7777"]
      interval: 15s
      timeout: 5s
      retries: 5
      start_period: 10s
    security_opt:
      - no-new-privileges:true

  # ── Core: Authentik IdP ──────────────────────────────────────

  authentik-server:
    image: {{ authentik_image | default('ghcr.io/goauthentik/server:2025.12') }}
    command: server
    restart: unless-stopped
    environment:
      AUTHENTIK_SECRET_KEY: ${AUTHENTIK_SECRET_KEY}
      AUTHENTIK_POSTGRESQL__HOST: postgres
      AUTHENTIK_POSTGRESQL__PORT: 5432
      AUTHENTIK_POSTGRESQL__USER: llamenos
      AUTHENTIK_POSTGRESQL__PASSWORD: ${PG_PASSWORD}
      AUTHENTIK_POSTGRESQL__NAME: authentik
      AUTHENTIK_BOOTSTRAP_TOKEN: ${AUTHENTIK_BOOTSTRAP_TOKEN}
    ports:
      - "{{ authentik_port | default(9000) }}:9000"
    depends_on:
      postgres:
        condition: service_healthy
    networks:
      - internal
    volumes:
      - authentik-media:/media
      - authentik-templates:/templates
      - {{ app_dir }}/authentik-blueprints:/blueprints/custom:ro
    healthcheck:
      test: ["CMD", "ak", "healthcheck"]
      interval: 30s
      timeout: 10s
      retries: 5
      start_period: 60s
    security_opt:
      - no-new-privileges:true
    deploy:
      resources:
        limits:
          memory: 512M

  authentik-worker:
    image: {{ authentik_image | default('ghcr.io/goauthentik/server:2025.12') }}
    command: worker
    restart: unless-stopped
    environment:
      AUTHENTIK_SECRET_KEY: ${AUTHENTIK_SECRET_KEY}
      AUTHENTIK_POSTGRESQL__HOST: postgres
      AUTHENTIK_POSTGRESQL__PORT: 5432
      AUTHENTIK_POSTGRESQL__USER: llamenos
      AUTHENTIK_POSTGRESQL__PASSWORD: ${PG_PASSWORD}
      AUTHENTIK_POSTGRESQL__NAME: authentik
    depends_on:
      postgres:
        condition: service_healthy
    networks:
      - internal
    volumes:
      - authentik-media:/media
      - authentik-templates:/templates
      - {{ app_dir }}/authentik-blueprints:/blueprints/custom:ro
    security_opt:
      - no-new-privileges:true
    deploy:
      resources:
        limits:
          memory: 512M

{% if watchtower_enabled | default(false) %}
  # ── Optional: Watchtower (Auto-Updates) ─────────────────────

  watchtower:
    image: {{ watchtower_image | default('containrrr/watchtower:1.7.1') }}
    restart: unless-stopped
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock
    environment:
      - WATCHTOWER_LABEL_ENABLE=true
      - WATCHTOWER_POLL_INTERVAL={{ watchtower_poll_interval | default(86400) }}
      - WATCHTOWER_CLEANUP=true
      - WATCHTOWER_LOG_LEVEL=${WATCHTOWER_LOG_LEVEL:-info}
      - REPO_USER=${GHCR_USERNAME:-}
      - REPO_PASS=${GHCR_TOKEN:-}
    logging:
      driver: json-file
      options:
        max-size: "5m"
        max-file: "3"
    security_opt:
      - no-new-privileges:true
{% endif %}

{% if 'signal' in compose_profiles %}
  # ── Optional: Signal Messaging ──────────────────────────────

  signal-cli:
    image: {{ signal_image }}
    restart: unless-stopped
    environment:
      - MODE=json-rpc
      - AUTO_RECEIVE_SCHEDULE=0 * * * *
    volumes:
      - signal-data:/home/.local/share/signal-cli
    networks:
      - internal
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:8080/v1/about"]
      interval: 30s
      timeout: 5s
      retries: 3
      start_period: 20s
    security_opt:
      - no-new-privileges:true
{% endif %}

volumes:
  postgres-data:
  caddy-data:
  caddy-config:
  minio-data:
  nostr-data:
  authentik-media:
  authentik-templates:
{% if 'asterisk' in compose_profiles %}
  asterisk-config:
{% endif %}
{% if 'signal' in compose_profiles %}
  signal-data:
{% endif %}

networks:
  web:
    driver: bridge
  internal:
    driver: bridge
    internal: true

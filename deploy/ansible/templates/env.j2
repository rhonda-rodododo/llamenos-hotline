# Llamenos Environment Variables — managed by Ansible
# Do not edit manually; changes will be overwritten on next deploy.
#
# Generated: {{ ansible_date_time.iso8601 | default('unknown') }}

# ─── Application ─────────────────────────────────────────────
ADMIN_PUBKEY={{ admin_pubkey }}
HOTLINE_NAME={{ hotline_name }}
ENVIRONMENT={{ environment | default('production') }}
HMAC_SECRET={{ hmac_secret }}
DEMO_MODE={{ demo_mode | default('') }}
DEV_RESET_SECRET={{ dev_reset_secret | default('') }}

# ─── PostgreSQL ──────────────────────────────────────────────
PG_PASSWORD={{ pg_password }}
PG_POOL_SIZE={{ pg_pool_size }}

# ─── Storage (RustFS — S3-compatible, bucket management handled by app) ──
STORAGE_ACCESS_KEY={{ storage_access_key }}
STORAGE_SECRET_KEY={{ storage_secret_key }}
STORAGE_SSE_ENABLED={{ storage_sse_enabled | default('true') }}

# ─── Telephony ───────────────────────────────────────────────
TWILIO_ACCOUNT_SID={{ twilio_account_sid }}
TWILIO_AUTH_TOKEN={{ twilio_auth_token }}
TWILIO_PHONE_NUMBER={{ twilio_phone_number }}

# ─── Transcription ───────────────────────────────────────────
WHISPER_URL=http://whisper:8080/v1/audio/transcriptions
WHISPER_MODEL={{ whisper_model }}
WHISPER_DEVICE={{ whisper_device }}

# ─── Nostr Relay (Core) ─────────────────────────────────────
SERVER_NOSTR_SECRET={{ server_nostr_secret }}
NOSTR_RELAY_URL={{ nostr_relay_url | default('ws://strfry:7777') }}

{% if 'asterisk' in compose_profiles %}
# ─── Asterisk ────────────────────────────────────────────────
ARI_USERNAME={{ ari_username }}
ARI_PASSWORD={{ ari_password }}
BRIDGE_SECRET={{ bridge_secret }}
HOTLINE_NUMBER={{ hotline_number | default('') }}
# SIP trunk auto-config — set all three to enable PJSIP auto-configuration at startup
SIP_PROVIDER={{ sip_provider | default('') }}
SIP_USERNAME={{ sip_username | default('') }}
SIP_PASSWORD={{ sip_password | default('') }}
# SIP WebRTC browser calling
ASTERISK_DOMAIN={{ asterisk_domain | default(domain) }}
ASTERISK_WSS_PORT={{ asterisk_wss_port | default(443) }}
STUN_SERVER={{ stun_server | default('stun:' + domain + ':3478') }}
TURN_SERVER={{ turn_server | default('turn:' + domain + ':3478') }}
TURN_SECRET={{ turn_secret }}
{% endif %}

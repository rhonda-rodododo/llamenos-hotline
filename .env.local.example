# Local dev vars — used when running bun dev:server against Docker backend
# Copy to .env.local (gitignored) and fill in your values
DATABASE_URL=postgresql://llamenos:yourpassword@localhost:5433/llamenos
STORAGE_ENDPOINT=http://localhost:9002
NOSTR_RELAY_URL=ws://localhost:7778

# Push notifications (Epic 86) — Web Push / VAPID
# Generate with: bun -e "const wp = require('web-push'); const k = wp.generateVAPIDKeys(); console.log('VAPID_PUBLIC_KEY=' + k.publicKey); console.log('VAPID_PRIVATE_KEY=' + k.privateKey)"
VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here

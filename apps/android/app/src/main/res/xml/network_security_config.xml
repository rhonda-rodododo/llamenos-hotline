<?xml version="1.0" encoding="utf-8"?>
<!--
    Network security configuration for llamenos (release).

    HTTPS only — no cleartext traffic permitted.
    Debug builds use app/src/debug/res/xml/network_security_config.xml
    which adds localhost and LAN exceptions.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>

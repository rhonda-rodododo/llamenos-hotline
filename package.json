{
  "name": "llamenos",
  "version": "0.35.0",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "imports": {},
  "scripts": {
    "dev": "vite",
    "dev:all": "concurrently -n vite,server,bridge -c cyan,green,magenta \"bun run dev\" \"bun run dev:server\" \"bun run dev:bridge\"",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "bun run deploy:site",
    "deploy:site": "cd site && bun run deploy",
    "dev:server": "bun --watch src/server/server.ts",
    "dev:bridge": "cd asterisk-bridge && bun run dev",
    "dev:docker": "docker compose --env-file deploy/docker/.env.dev.defaults -f deploy/docker/docker-compose.yml -f deploy/docker/docker-compose.dev.yml --profile asterisk up -d postgres rustfs strfry authentik-server authentik-worker asterisk",
    "dev:docker:down": "docker compose --env-file deploy/docker/.env.dev.defaults -f deploy/docker/docker-compose.yml -f deploy/docker/docker-compose.dev.yml --profile asterisk down",
    "start": "bun src/server/server.ts",
    "start:bun": "bun src/server/server.ts",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "format": "biome format --write src/",
    "typecheck": "bunx tsc --noEmit",
    "bootstrap-admin": "bun run scripts/bootstrap-admin.ts",
    "test": "bunx playwright test",
    "test:unit": "bun test src/ --bail --path-ignore-patterns='**/*.integration.test.ts'",
    "test:integration": "bun test .integration. --bail",
    "test:api": "bunx playwright test --project=api",
    "test:e2e": "bunx playwright test --project=ui",
    "test:interactive": "bunx playwright test --ui",
    "test:live": "bunx playwright test --config playwright.live.config.ts",
    "test:all": "bun run test:unit && bun run test:integration && bun run test:api && bun run test:e2e",
    "site:dev": "cd site && bun run dev",
    "site:build": "cd site && bun run build",
    "changelog": "git-cliff --output CHANGELOG.md",
    "changelog:preview": "git-cliff --unreleased",
    "version:bump": "bun run scripts/bump-version.ts",
    "prepare": "lefthook install || true"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1021.0",
    "@hono/node-server": "^1.19.12",
    "@hono/node-ws": "^1.3.0",
    "@hono/zod-openapi": "^1.2.4",
    "@huggingface/transformers": "^3.8.1",
    "@noble/ciphers": "^2.1.1",
    "@noble/curves": "^2.0.1",
    "@noble/hashes": "^2.0.1",
    "@scalar/hono-api-reference": "^0.10.5",
    "@scure/base": "^2.0.0",
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.0",
    "@tanstack/react-query": "^5.96.0",
    "@tanstack/react-query-devtools": "^5.96.0",
    "@tanstack/react-router": "^1.168.10",
    "@tanstack/router-plugin": "^1.167.12",
    "@vonage/client-sdk": "^2.3.0",
    "axios": "^1.14.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "drizzle-orm": "^0.45.2",
    "fflate": "^0.8.2",
    "hono": "^4.12.9",
    "i18next": "^25.10.10",
    "i18next-http-backend": "^3.0.4",
    "jose": "^6.2.2",
    "jssip": "^3.13.6",
    "lucide-react": "^1.7.0",
    "next-themes": "^0.4.6",
    "nostr-tools": "^2.23.3",
    "plivo-browser-sdk": "^2.2.21",
    "postgres": "^3.4.8",
    "qrcode.react": "^4.2.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^16.6.6",
    "react-phone-number-input": "^3.4.16",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "web-push": "^3.6.7",
    "ws": "^8.20.0",
    "zod": "^4.3.6",
    "zod-openapi": "^5.4.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@cloudflare/workers-types": "^4.20260401.1",
    "@evilmartians/lefthook": "^2.1.4",
    "@playwright/test": "^1.59.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/bun": "^1.3.11",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/web-push": "^3.6.4",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.2.0",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.10",
    "shadcn": "^4.1.2",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "twilio": "^5.13.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.3",
    "vite-plugin-pwa": "^1.2.0",
    "workbox-precaching": "^7.4.0",
    "workbox-routing": "^7.4.0",
    "wrangler": "^4.79.0"
  }
}

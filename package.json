{
  "name": "llamenos",
  "version": "0.20.0",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "imports": {},
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "bun run deploy:site",
    "deploy:site": "cd site && bun run deploy",
    "dev:server": "bun --watch src/server/server.ts",
    "dev:docker": "docker compose --env-file deploy/docker/.env.dev.defaults -f deploy/docker/docker-compose.yml -f deploy/docker/docker-compose.dev.yml --profile asterisk up -d postgres minio strfry asterisk asterisk-bridge",
    "dev:docker:down": "docker compose --env-file deploy/docker/.env.dev.defaults -f deploy/docker/docker-compose.yml -f deploy/docker/docker-compose.dev.yml --profile asterisk down",
    "start": "bun src/server/server.ts",
    "start:bun": "bun src/server/server.ts",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "format": "biome format --write src/",
    "typecheck": "bunx tsc --noEmit",
    "bootstrap-admin": "bun run scripts/bootstrap-admin.ts",
    "test": "bunx playwright test",
    "test:unit": "bun test src/",
    "test:api": "bunx playwright test --project=api",
    "test:e2e": "bunx playwright test --project=ui",
    "test:interactive": "bunx playwright test --ui",
    "test:live": "bunx playwright test --config playwright.live.config.ts",
    "test:all": "bun test src/ && bunx playwright test",
    "site:dev": "cd site && bun run dev",
    "site:build": "cd site && bun run build",
    "changelog": "git-cliff --output CHANGELOG.md",
    "changelog:preview": "git-cliff --unreleased",
    "version:bump": "bun run scripts/bump-version.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1014.0",
    "@hono/node-server": "^1.19.11",
    "@hono/node-ws": "^1.3.0",
    "@huggingface/transformers": "^3.8.1",
    "@noble/ciphers": "^2.1.1",
    "@noble/curves": "^2.0.1",
    "@noble/hashes": "^2.0.1",
    "@scure/base": "^2.0.0",
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.0",
    "@tanstack/react-router": "^1.168.2",
    "@tanstack/router-plugin": "^1.167.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.12.8",
    "i18next": "^25.10.4",
    "lucide-react": "^0.563.0",
    "next-themes": "^0.4.6",
    "nostr-tools": "^2.23.3",
    "postgres": "^3.4.8",
    "qrcode.react": "^4.2.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^16.6.1",
    "react-phone-number-input": "^3.4.16",
    "recharts": "^3.8.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@cloudflare/workers-types": "^4.20260317.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.2.0",
    "drizzle-kit": "^0.31.10",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "twilio": "^5.13.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.2.0",
    "wrangler": "^4.76.0"
  }
}
